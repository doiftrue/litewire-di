{
    "name": "doiftrue/litewire-di",
    "description": "A tiny single-file PSR-11-style autowire DI container for PHP, with no dependencies.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Timur Kamaev",
            "email": "tnkamaev@gmail.com",
            "homepage": "https://wp-kama.com/"
        }
    ],
    "scripts": {
        "phpunit": "./vendor/bin/phpunit",
        "phpstan": "./vendor/bin/phpstan analyse"
    },
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6 || ^10.5 || ^11.5 || ^12.0 || ^13.2",
        "phpstan/phpstan": "^2.2.5"
    },
    "autoload": {
        "psr-4": {
            "Kama\\LiteWireDI\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kama\\LiteWireDI\\Tests\\": "tests/"
        }
    }
}
