<?xml version="1.0" encoding="UTF-8"?>
<!-- Coverage runs on PHP 8.5 with the latest supported PHPUnit version. -->
<phpunit
	bootstrap="vendor/autoload.php"
	backupGlobals="false"
	cacheResult="false"
	colors="true"
>
	<testsuites>
		<testsuite name="Unit">
			<directory suffix="Test.php">./tests</directory>
		</testsuite>
	</testsuites>
	<source>
		<include>
			<file>./Container.php</file>
		</include>
	</source>
	<php>
		<ini name="display_errors" value="On" />
		<ini name="display_startup_errors" value="On" />
	</php>
</phpunit>
